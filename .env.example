# =============================================================================
# Avenue Locksmith — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Telegram Bot (callback, contact form, quote, and chat notifications)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------------------------------------------------------------------------
# OpenAI (powers the live chat AI assistant)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Supabase (quote image uploads and storage)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Google (Maps embed + Search Console verification)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
